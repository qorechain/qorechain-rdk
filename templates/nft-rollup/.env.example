# Target network: testnet (qorechain-diana) or mainnet (qorechain-vladi).
QORE_NETWORK=testnet

# Endpoints — override the localhost defaults with your node URLs, or use the
# public endpoints (mainnet: api/rpc/evm.qore.host; testnet shown below).
QORE_REST_URL=https://api-testnet.qore.host
QORE_RPC_URL=https://rpc-testnet.qore.host
QORE_EVM_RPC_URL=https://evm-testnet.qore.host

# Operator signing key — NEVER commit a real value. Provide one of:
QORE_OPERATOR_PRIVATE_KEY_HEX=
QORE_MNEMONIC=

# Optional overrides.
QORE_ROLLUP_ID=my-nft-rollup
QORE_GAS_PRICE=0.15uqor
