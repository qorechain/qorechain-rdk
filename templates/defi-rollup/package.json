{
  "name": "defi-rollup",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "A QoreChain DeFi rollup (zk-SNARK / dedicated / native / EIP-1559 / EVM) with a reference SNARK prover.",
  "scripts": {
