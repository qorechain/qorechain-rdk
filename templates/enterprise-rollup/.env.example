# Target network: testnet (qorechain-diana) or mainnet (qorechain-vladi).
QORE_NETWORK=testnet

# Endpoints — override the localhost defaults with your node URLs.
QORE_REST_URL=
QORE_RPC_URL=
QORE_EVM_RPC_URL=

# Operator signing key — NEVER commit a real value. Provide one of:
QORE_OPERATOR_PRIVATE_KEY_HEX=
QORE_MNEMONIC=

# Optional overrides.
QORE_ROLLUP_ID=my-enterprise-rollup
QORE_GAS_PRICE=0.025uqor
