# Target network: "testnet" (qorechain-diana) or "mainnet" (qorechain-vladi).
# Defaults to testnet for safety.
QORE_NETWORK=testnet

# Cosmos REST (LCD) endpoint URL — rollup/batch/DA reads.
QORE_REST_URL=
# Consensus RPC endpoint URL — transaction broadcast.
QORE_RPC_URL=
# gRPC endpoint (host:port) — typed queries.
QORE_GRPC_URL=
# EVM + qor_ JSON-RPC endpoint URL — qor_* rollup methods (status, suggestProfile, DA blob status).
QORE_EVM_RPC_URL=

# Operator / sequencer signing key. NEVER commit a real value.
# Provide EITHER a BIP39 mnemonic OR a hex private key — not both.
QORE_MNEMONIC=
QORE_OPERATOR_PRIVATE_KEY_HEX=

# Set to 1 to enable the opt-in live-testnet integration tests.
QORE_LIVE_TEST=
